---
import type { GetStaticPaths } from 'astro';
import Layout from '../../components/Layout.astro';
import {
  getEditionYears,
  loadEdition,
  countryName,
  languageName,
  formatPersonName,
  loadCountries,
  loadLanguages,
} from '../../lib/data';

export const getStaticPaths: GetStaticPaths = () => {
  return getEditionYears().map((year) => ({ params: { year: String(year) } }));
};

const { year } = Astro.params;
const yearNum = Number(year);
const edition = loadEdition(yearNum)!;
const countries = loadCountries();
const languages = loadLanguages();

const countryColors: Record<string, string> = {
  bel: '#e30613',
  nld: '#ff6600',
  lux: '#00a2e0',
};
const accent = countryColors[edition.country] || '#2563eb';

const langIcons: Record<string, string> = {
  en: '🇬🇧',
  fr: '🇫🇷',
  nl: '🇳🇱',
  de: '🇩🇪',
  es: '🇪🇸',
  sl: '🇸🇮',
  sw: '🇸🇪',
  fl: '🇧🇪',
  zz: '📝',
};
---

<Layout
  title={`BxMO ${year} — ${edition.location}`}
  description={`Details for the ${year} Benelux Mathematical Olympiad in ${edition.location}`}
  hero={true}
>
  <Fragment slot="hero">
    <div class="edition-hero" style={`--accent: ${accent}`}>
      <span class="hero-year">{year}</span>
      <h1>{edition.location}</h1>
      <p>
        Hosted by {countryName(edition.country, countries)}
      </p>
    </div>
  </Fragment>

  <!-- Edition info -->
  <div class="info-card">
    <Fragment
      set:html={edition.info
        .replace(
          /\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,
          '<a href="$2" target="_blank" rel="noopener">$1</a>',
        )
        .replace(/\n/g, '<br>')}
    />
  </div>

  <!-- Problem papers -->
  <h2>Problem Papers</h2>
  <div class="pdf-grid">
    {
      edition.problems.map((p) => (
        <a
          href={`/problems/bxmo-problems-${year}-${p.lang}.pdf`}
          class="pdf-link"
        >
          <span class="pdf-icon">{langIcons[p.lang] || '📄'}</span>
          <span class="pdf-label">
            {p.lang === 'zz' ? 'Solutions' : languageName(p.lang, languages)}
          </span>
        </a>
      ))
    }
  </div>

  <!-- Delegations -->
  <h2>Delegations</h2>
  <div class="delegations-grid">
    {
      edition.delegations.map((d) => {
        const cAccent = countryColors[d.country] || '#2563eb';
        return (
          <div class="delegation-card" style={`--c-accent: ${cAccent}`}>
            <div class="delegation-header">
              <h3>{countryName(d.country, countries)}</h3>
            </div>
            <div class="delegation-body">
              {d.leader && (
                <p>
                  <span class="role">Leader</span>
                  {formatPersonName(d.leader)}
                </p>
              )}
              {d.deputies && d.deputies.length > 0 && (
                <p>
                  <span class="role">
                    {d.deputies.length === 1 ? 'Deputy' : 'Deputies'}
                  </span>
                  {d.deputies.map((dep) => formatPersonName(dep)).join(', ')}
                </p>
              )}
            </div>
          </div>
        );
      })
    }
  </div>

  <div class="bottom-nav">
    <a href={`/results/${year}`} class="results-link">
      View results for BxMO {year} →
    </a>
  </div>
</Layout>

<style>
  .edition-hero {
    text-align: center;
  }
  .hero-year {
    display: inline-block;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.2);
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    margin-bottom: 0.75rem;
  }
  .edition-hero h1 {
    margin-bottom: 0.25em;
  }
  .edition-hero p {
    opacity: 0.85;
    font-size: 1.1rem;
  }

  .info-card {
    background: var(--color-surface);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--radius-sm);
    padding: 1.25rem 1.5rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .pdf-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .pdf-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 99px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.15s,
      box-shadow 0.15s,
      background 0.15s;
  }
  .pdf-link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    background: var(--color-primary-light);
    text-decoration: none;
  }
  .pdf-icon {
    font-size: 1.15rem;
  }

  .delegations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .delegation-card {
    border-radius: var(--radius);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .delegation-header {
    background: linear-gradient(
      135deg,
      var(--c-accent),
      color-mix(in srgb, var(--c-accent) 70%, #1a1a2e)
    );
    padding: 0.75rem 1.25rem;
  }
  .delegation-header h3 {
    margin: 0;
    color: white;
    font-size: 1rem;
  }
  .delegation-body {
    padding: 1rem 1.25rem;
  }
  .delegation-body p {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .delegation-body p:last-child {
    margin-bottom: 0;
  }
  .role {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .bottom-nav {
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
  .results-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.5rem;
    border-radius: 99px;
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    transition:
      background 0.15s,
      transform 0.15s;
  }
  .results-link:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .delegations-grid {
      grid-template-columns: 1fr;
    }
    .pdf-link {
      padding: 0.5rem 1rem;
      font-size: 0.85rem;
    }
  }
</style>
