---
import type { GetStaticPaths } from 'astro';
import Layout from '../../components/Layout.astro';
import {
  getEditionYears,
  loadEdition,
  countryName,
  participantName,
  loadCountries,
} from '../../lib/data';
import { computeAwards, countMedals, AWARD_LABELS } from '../../lib/awards';
import {
  rankParticipants,
  computeCountryStats,
  computeProblemStats,
} from '../../lib/stats';

export const getStaticPaths: GetStaticPaths = () => {
  return getEditionYears().map((year) => ({ params: { year: String(year) } }));
};

const { year } = Astro.params;
const yearNum = Number(year);
const edition = loadEdition(yearNum)!;
const countries = loadCountries();
const years = getEditionYears();

const withAwards = computeAwards(
  edition.participants,
  edition.thresholds,
  edition.honourableMentions,
);
const ranked = rankParticipants(withAwards);
const medals = countMedals(withAwards);
const countryStats = computeCountryStats(withAwards, countries);
const problemStats = computeProblemStats(withAwards);

const prevYear = years[years.indexOf(yearNum) - 1];
const nextYear = years[years.indexOf(yearNum) + 1];

// Chart data for client-side rendering
const chartCountryData = JSON.stringify(
  countryStats.map((cs) => ({
    name: cs.countryName,
    min: cs.minScore,
    q1: cs.q1,
    median: cs.median,
    q3: cs.q3,
    max: cs.maxScore,
    avg: cs.avgScore,
  })),
);
const chartProblemData = JSON.stringify(
  problemStats.map((ps) => ({
    label: `P${ps.problem}`,
    histogram: ps.histogram,
    mean: ps.mean,
  })),
);

function medalClass(award: string | null): string {
  if (!award) return '';
  return `medal medal-${award}`;
}

function medalLabel(award: string | null): string {
  if (!award) return '';
  return AWARD_LABELS[award] ?? '';
}
---

<Layout
  title={`BxMO ${year} Results`}
  description={`Results and statistics for the ${year} Benelux Mathematical Olympiad in ${edition.location}`}
>
  <div class="page-nav">
    {prevYear && <a href={`/results/${prevYear}`}>← {prevYear}</a>}
    <span class="spacer"></span>
    {nextYear && <a href={`/results/${nextYear}`}>{nextYear} →</a>}
  </div>

  <h1>BxMO {year} <span class="h1-sep">—</span> {edition.location}</h1>
  <p class="subtitle">
    {countryName(edition.country, countries)} ·
    {edition.participants.length} participants ·
    {edition.delegations.length} countries
  </p>

  <!-- Medal summary -->
  <div class="medal-summary">
    <div class="medal-cards">
      <div class="medal-card medal-card-gold">
        <span class="medal-count">{medals.gold}</span>
        <span class="medal-label">Gold</span>
        <span class="medal-threshold">≥{edition.thresholds.gold}</span>
      </div>
      <div class="medal-card medal-card-silver">
        <span class="medal-count">{medals.silver}</span>
        <span class="medal-label">Silver</span>
        <span class="medal-threshold">≥{edition.thresholds.silver}</span>
      </div>
      <div class="medal-card medal-card-bronze">
        <span class="medal-count">{medals.bronze}</span>
        <span class="medal-label">Bronze</span>
        <span class="medal-threshold">≥{edition.thresholds.bronze}</span>
      </div>
      {
        edition.honourableMentions && medals.hm > 0 && (
          <div class="medal-card medal-card-hm">
            <span class="medal-count">{medals.hm}</span>
            <span class="medal-label">HM</span>
            <span class="medal-threshold">full score on a problem</span>
          </div>
        )
      }
    </div>
  </div>

  <!-- Individual results -->
  <h2>Individual Results</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Country</th>
          <th class="num">P1</th>
          <th class="num">P2</th>
          <th class="num">P3</th>
          <th class="num">P4</th>
          <th class="num">Total</th>
          <th>Award</th>
        </tr>
      </thead>
      <tbody>
        {
          ranked.map((p) => (
            <tr>
              <td class="num">{p.rank}</td>
              <td>{participantName(p)}</td>
              <td>{countryName(p.country, countries)}</td>
              <td class="num">{p.scores[0]}</td>
              <td class="num">{p.scores[1]}</td>
              <td class="num">{p.scores[2]}</td>
              <td class="num">{p.scores[3]}</td>
              <td class="num">
                <strong>{p.totalScore}</strong>
              </td>
              <td>
                {p.award && (
                  <span class={medalClass(p.award)}>{medalLabel(p.award)}</span>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <!-- Country statistics -->
  <h2>Country Statistics</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Country</th>
          <th class="num">N</th>
          <th class="num">Avg</th>
          <th class="num">Min</th>
          <th class="num">Q1</th>
          <th class="num">Med</th>
          <th class="num">Q3</th>
          <th class="num">Max</th>
          <th class="num">🥇</th>
          <th class="num">🥈</th>
          <th class="num">🥉</th>
        </tr>
      </thead>
      <tbody>
        {
          countryStats.map((cs) => (
            <tr>
              <td>{cs.countryName}</td>
              <td class="num">{cs.count}</td>
              <td class="num">{cs.avgScore.toFixed(1)}</td>
              <td class="num">{cs.minScore}</td>
              <td class="num">{cs.q1.toFixed(1)}</td>
              <td class="num">{cs.median.toFixed(1)}</td>
              <td class="num">{cs.q3.toFixed(1)}</td>
              <td class="num">{cs.maxScore}</td>
              <td class="num">{cs.gold || ''}</td>
              <td class="num">{cs.silver || ''}</td>
              <td class="num">{cs.bronze || ''}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <!-- Country score chart -->
  <div class="chart-container" style="max-width: 100%; margin-bottom: 2rem;">
    <canvas id="country-chart"></canvas>
  </div>

  <!-- Problem statistics -->
  <h2>Problem Statistics</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Problem</th>
          <th class="num">Mean</th>
          <th class="num">Median</th>
          <th class="num">Std Dev</th>
          {[0, 1, 2, 3, 4, 5, 6, 7].map((s) => <th class="num">{s}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          problemStats.map((ps) => (
            <tr>
              <td>
                <strong>P{ps.problem}</strong>
              </td>
              <td class="num">{ps.mean.toFixed(2)}</td>
              <td class="num">{ps.median.toFixed(1)}</td>
              <td class="num">{ps.stddev.toFixed(2)}</td>
              {ps.histogram.map((count) => (
                <td class="num">{count}</td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <!-- Problem score histogram -->
  <div class="chart-container" style="max-width: 100%; margin-bottom: 2rem;">
    <canvas id="problem-chart"></canvas>
  </div>

  <!-- Links -->
  <h2>Downloads</h2>
  <p>
    <a href={`/results/${year}.csv`}>📊 Download results as CSV</a>
    &nbsp;·&nbsp;
    <a href={`/edition/${year}`}>📋 Edition details and problem PDFs</a>
  </p>
</Layout>

<style>
  .page-nav {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
  }
  .page-nav a {
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    font-weight: 500;
    transition: background 0.15s;
  }
  .page-nav a:hover {
    background: var(--color-primary);
    color: white;
    text-decoration: none;
  }
  .page-nav .spacer {
    flex: 1;
  }
  .h1-sep {
    color: var(--color-text-muted);
    font-weight: 400;
  }
  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
  }
  .medal-summary {
    margin-bottom: 2rem;
  }
  .medal-cards {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .medal-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 1.5rem;
    border-radius: var(--radius);
    min-width: 100px;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .medal-count {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .medal-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }
  .medal-threshold {
    font-size: 0.7rem;
    opacity: 0.7;
    margin-top: 0.15rem;
  }
  .medal-card-gold {
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    color: #92400e;
  }
  .medal-card-silver {
    background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
    color: #475569;
  }
  .medal-card-bronze {
    background: linear-gradient(135deg, #fed7aa, #fdba74);
    color: #9a3412;
  }
  .medal-card-hm {
    background: linear-gradient(135deg, #d1fae5, #a7f3d0);
    color: #065f46;
  }
  .table-wrap {
    overflow-x: auto;
    margin-bottom: 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }
  .table-wrap table {
    margin: 0;
  }
  .table-wrap th:first-child,
  .table-wrap td:first-child {
    padding-left: 1rem;
  }
  th.num,
  td.num {
    text-align: right;
  }
  @media (max-width: 640px) {
    .medal-cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
    .medal-card {
      min-width: unset;
      padding: 0.75rem;
    }
    .medal-count {
      font-size: 1.5rem;
    }
  }
</style>

<script is:inline define:vars={{ chartCountryData, chartProblemData }}>
  async function initCharts() {
    const { Chart, registerables } =
      await import('https://cdn.jsdelivr.net/npm/chart.js@4/+esm');
    Chart.register(...registerables);

    const countryData = JSON.parse(chartCountryData);
    const problemData = JSON.parse(chartProblemData);

    // Country score distribution — floating bar chart showing min/Q1/median/Q3/max
    const countryCtx = document.getElementById('country-chart');
    if (countryCtx && countryData.length > 0) {
      const labels = countryData.map((c) => c.name);
      new Chart(countryCtx, {
        type: 'bar',
        data: {
          labels,
          datasets: [
            {
              label: 'Score Range (Min–Max)',
              data: countryData.map((c) => [c.min, c.max]),
              backgroundColor: 'rgba(26, 86, 219, 0.15)',
              borderColor: 'rgba(26, 86, 219, 0.3)',
              borderWidth: 1,
              borderSkipped: false,
            },
            {
              label: 'IQR (Q1–Q3)',
              data: countryData.map((c) => [c.q1, c.q3]),
              backgroundColor: 'rgba(26, 86, 219, 0.4)',
              borderColor: 'rgba(26, 86, 219, 0.6)',
              borderWidth: 1,
              borderSkipped: false,
            },
            {
              label: 'Average',
              data: countryData.map((c) => c.avg),
              type: 'line',
              borderColor: '#d4a017',
              backgroundColor: '#d4a017',
              pointRadius: 5,
              pointStyle: 'diamond',
              borderWidth: 2,
              fill: false,
            },
          ],
        },
        options: {
          responsive: true,
          plugins: {
            title: { display: true, text: 'Score Distribution by Country' },
            legend: { position: 'bottom' },
          },
          scales: {
            y: {
              beginAtZero: true,
              title: { display: true, text: 'Total Score' },
            },
          },
        },
      });
    }

    // Problem score histogram — grouped bar chart
    const problemCtx = document.getElementById('problem-chart');
    if (problemCtx && problemData.length > 0) {
      const colors = [
        'rgba(26, 86, 219, 0.6)',
        'rgba(212, 160, 23, 0.6)',
        'rgba(184, 115, 51, 0.6)',
        'rgba(91, 138, 114, 0.6)',
      ];
      new Chart(problemCtx, {
        type: 'bar',
        data: {
          labels: ['0', '1', '2', '3', '4', '5', '6', '7'],
          datasets: problemData.map((p, i) => ({
            label: `${p.label} (μ=${p.mean.toFixed(1)})`,
            data: p.histogram,
            backgroundColor: colors[i % colors.length],
          })),
        },
        options: {
          responsive: true,
          plugins: {
            title: { display: true, text: 'Score Distribution by Problem' },
            legend: { position: 'bottom' },
          },
          scales: {
            x: { title: { display: true, text: 'Score' } },
            y: {
              beginAtZero: true,
              title: { display: true, text: 'Number of Contestants' },
            },
          },
        },
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCharts);
  } else {
    initCharts();
  }
</script>
