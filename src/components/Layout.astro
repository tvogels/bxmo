---
interface Props {
  title?: string;
  description?: string;
  hero?: boolean;
}

const {
  title = 'BxMO',
  description = 'Benelux Mathematical Olympiad — Results and Statistics',
  hero = false,
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/search', label: 'Search' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-logo">
          <span class="logo-mark">BxMO</span>
        </a>
        <nav class="site-nav">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'nav-link',
                  {
                    active:
                      currentPath === item.href ||
                      (item.href !== '/' && currentPath.startsWith(item.href)),
                  },
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    {
      hero && (
        <div class="hero">
          <div class="container">
            <slot name="hero" />
          </div>
        </div>
      )
    }

    <main class:list={['container', { 'has-hero': hero }]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          © {new Date().getFullYear()} Benelux Mathematical Olympiad
        </p>
      </div>
    </footer>

    <script is:inline>
      document.querySelectorAll('.table-wrap').forEach((el) => {
        el.addEventListener('scroll', () => {
          const atEnd = el.scrollLeft + el.clientWidth >= el.scrollWidth - 2;
          el.classList.toggle('scrolled-end', atEnd);
        });
      });
    </script>

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --color-bg: #f8f9fc;
        --color-surface: #ffffff;
        --color-text: #1a1a2e;
        --color-text-muted: #64748b;
        --color-primary: #2563eb;
        --color-primary-dark: #1d4ed8;
        --color-primary-light: #eff4ff;
        --color-accent: #f59e0b;
        --color-border: #e2e8f0;
        --color-gold: #d97706;
        --color-silver: #64748b;
        --color-bronze: #c2410c;
        --color-hm: #059669;
        --radius: 10px;
        --radius-sm: 6px;
        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
        --shadow: 0 1px 3px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04);
        --shadow-md:
          0 4px 6px rgba(0, 0, 0, 0.05), 0 2px 4px rgba(0, 0, 0, 0.04);
        --shadow-lg:
          0 10px 25px rgba(0, 0, 0, 0.08), 0 4px 10px rgba(0, 0, 0, 0.04);
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-mono: 'SF Mono', 'Fira Code', monospace;
      }

      html {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem;
        width: 100%;
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      h1,
      h2,
      h3,
      h4 {
        line-height: 1.2;
        margin-bottom: 0.5em;
        letter-spacing: -0.02em;
      }
      h1 {
        font-size: 2.25rem;
        font-weight: 800;
      }
      h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-top: 2.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--color-border);
      }
      h3 {
        font-size: 1.15rem;
        font-weight: 600;
        margin-top: 1.5rem;
      }

      p {
        margin-bottom: 1em;
      }

      /* Header */
      .site-header {
        background: var(--color-surface);
        border-bottom: 1px solid var(--color-border);
        padding: 0 0;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.92);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        height: 56px;
      }
      .site-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text);
        font-size: 1.25rem;
      }
      .site-logo:hover {
        text-decoration: none;
      }
      .logo-mark {
        font-weight: 800;
        font-size: 1.3rem;
        background: linear-gradient(135deg, var(--color-primary), #7c3aed);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.03em;
      }
      .site-nav {
        display: flex;
        gap: 0.15rem;
      }
      .nav-link {
        padding: 0.4rem 0.85rem;
        border-radius: 99px;
        color: var(--color-text-muted);
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.15s;
      }
      .nav-link:hover {
        background: var(--color-primary-light);
        text-decoration: none;
        color: var(--color-primary);
      }
      .nav-link.active {
        background: var(--color-primary);
        color: white;
        font-weight: 600;
      }

      /* Hero */
      .hero {
        background: linear-gradient(
          135deg,
          #1e3a5f 0%,
          #2563eb 50%,
          #7c3aed 100%
        );
        color: white;
        padding: 3.5rem 0 3rem;
      }
      .hero h1 {
        color: white;
        font-size: 2.75rem;
        margin-bottom: 0.3em;
      }
      .hero p {
        color: rgba(255, 255, 255, 0.85);
        font-size: 1.15rem;
        margin-bottom: 0;
      }

      /* Main */
      main {
        flex: 1;
        padding-top: 3rem;
        padding-bottom: 3rem;
      }
      main.has-hero {
        padding-top: 2.5rem;
      }
      main > :first-child {
        margin-top: 0;
      }

      /* Footer */
      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 2rem 0;
        color: var(--color-text-muted);
        font-size: 0.8rem;
        text-align: center;
        background: var(--color-surface);
      }

      /* Card */
      .card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        padding: 1.25rem;
        box-shadow: var(--shadow-sm);
      }

      /* Table wrapper — scrollable container with scroll hint */
      .table-wrap {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-radius: var(--radius);
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        margin-bottom: 2rem;
      }
      .table-wrap table {
        margin: 0;
      }
      .table-wrap th:first-child,
      .table-wrap td:first-child {
        padding-left: 1rem;
      }
      .table-wrap th:last-child,
      .table-wrap td:last-child {
        padding-right: 1rem;
      }
      @media (max-width: 768px) {
        .table-wrap {
          box-shadow: inset -24px 0 20px -12px rgba(0, 0, 0, 0.15);
        }
        .table-wrap.scrolled-end {
          box-shadow: none;
        }
      }

      /* Table */
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
      }
      th,
      td {
        padding: 0.6rem 0.75rem;
        text-align: left;
        border-bottom: 1px solid var(--color-border);
      }
      th {
        background: var(--color-bg);
        font-weight: 600;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-text-muted);
      }
      td.num {
        text-align: right;
        font-variant-numeric: tabular-nums;
        font-feature-settings: 'tnum';
      }
      tbody tr {
        transition: background 0.1s;
      }
      tbody tr:hover {
        background: var(--color-primary-light);
      }

      /* Medal badges */
      .medal {
        display: inline-flex;
        align-items: center;
        gap: 0.25em;
        padding: 0.2em 0.6em;
        border-radius: 99px;
        font-size: 0.75rem;
        font-weight: 600;
        line-height: 1.4;
        white-space: nowrap;
      }
      .medal-gold {
        background: linear-gradient(135deg, #fef3c7, #fde68a);
        color: #92400e;
        box-shadow: 0 1px 2px rgba(217, 119, 6, 0.15);
      }
      .medal-silver {
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        color: #475569;
        box-shadow: 0 1px 2px rgba(100, 116, 139, 0.15);
      }
      .medal-bronze {
        background: linear-gradient(135deg, #fed7aa, #fdba74);
        color: #9a3412;
        box-shadow: 0 1px 2px rgba(194, 65, 12, 0.15);
      }
      .medal-hm {
        background: linear-gradient(135deg, #d1fae5, #a7f3d0);
        color: #065f46;
        box-shadow: 0 1px 2px rgba(5, 150, 105, 0.15);
      }

      /* Responsive */
      @media (max-width: 640px) {
        .header-inner {
          height: auto;
          padding: 0.6rem 0;
          flex-direction: column;
          gap: 0.4rem;
        }
        .hero {
          padding: 2.5rem 0 2rem;
        }
        .hero h1 {
          font-size: 2rem;
        }
        h1 {
          font-size: 1.75rem;
        }
        h2 {
          font-size: 1.25rem;
        }
        table {
          font-size: 0.78rem;
        }
        th,
        td {
          padding: 0.4rem 0.5rem;
        }
        th {
          position: static;
        }
      }

      /* Grid helpers */
      .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }
      @media (max-width: 768px) {
        .grid-2 {
          grid-template-columns: 1fr;
        }
      }

      /* Chart container */
      .chart-container {
        position: relative;
        width: 100%;
        max-width: 600px;
      }
    </style>
  </body>
</html>
